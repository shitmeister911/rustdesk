# .env.example — RustDesk Server OSS configuration template
#
# Copy this file to .env and fill in your values BEFORE running install.sh:
#   cp .env.example .env
#   nano .env
#
# The .env file is git-ignored. Never commit it — it contains your server IP.
# Only .env.example is tracked in the repo.

# ── Required ──────────────────────────────────────────────────────────────────

# Public IP address or FQDN of this server.
# Used by hbbs to tell clients where to reach the relay server (hbbr).
# Must be reachable from the internet — not a private or loopback address.
SERVER_IP=203.0.113.10

# ── Admin user ────────────────────────────────────────────────────────────────

# Non-root user created for server management.
# This user gets sudo and docker group membership.
# Password is locked — SSH key-only access only.
ADMIN_USER=rdadmin

# ── SSH ───────────────────────────────────────────────────────────────────────

# Changing from 22 reduces automated brute-force and scanning noise.
# Remember to open this port in your cloud provider's firewall too.
# Match this to your windows-ssh-config-example.txt Port value.
SSH_PORT=2222

# ── RustDesk data directory ───────────────────────────────────────────────────

# Absolute path where RustDesk stores its ed25519 key pair and SQLite database.
# Back up this directory — losing id_ed25519 means all clients must reconfigure.
RUSTDESK_DATA_DIR=/opt/rustdesk/data

# ── Docker log limits ─────────────────────────────────────────────────────────

# Docker's json-file driver rotates logs natively — no logrotate.d needed.
# 3 files × 10m = 30 MB max per container. Increase for busier servers.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3

# ── Unattended-upgrades email (optional) ──────────────────────────────────────

# Leave blank to silence notifications.
# Set to a real email to receive security patch reports.
# Requires a working MTA (e.g. nullmailer, ssmtp) configured on the server.
UNATTENDED_UPGRADES_EMAIL=
